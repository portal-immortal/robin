---
// Reusable call-to-action button. Renders as <a> when `href` is provided,
// otherwise as a native <button> (e.g. for form submits or JS handlers).
interface Props {
  href?: string;
  variant?: 'primary' | 'secondary' | 'outline' | 'ghost';
  size?: 'sm' | 'md' | 'lg';
  type?: 'button' | 'submit' | 'reset';
  class?: string;
  ariaLabel?: string;
}

const {
  href,
  variant = 'primary',
  size = 'md',
  type = 'button',
  class: className = '',
  ariaLabel,
} = Astro.props;

const base =
  'inline-flex min-h-[44px] items-center justify-center gap-2 rounded-full font-semibold transition-all duration-200 focus-visible:outline-hidden disabled:cursor-not-allowed disabled:opacity-50';

const variants: Record<string, string> = {
  primary:
    'bg-gradient-emerald text-white shadow-soft hover:shadow-card hover:-translate-y-0.5 active:translate-y-0',
  secondary:
    'bg-secondary-400 text-primary-950 shadow-gold hover:bg-secondary-300 hover:-translate-y-0.5 active:translate-y-0',
  outline:
    'border-2 border-primary-600 text-primary-700 hover:bg-primary-50 dark:text-primary-200 dark:hover:bg-primary-900',
  ghost: 'text-primary-700 hover:bg-primary-50 dark:text-primary-200 dark:hover:bg-primary-900',
};

const sizes: Record<string, string> = {
  sm: 'px-4 py-2 text-sm',
  md: 'px-6 py-3 text-base',
  lg: 'px-8 py-4 text-lg',
};

const classes = `${base} ${variants[variant]} ${sizes[size]} ${className}`;
const Tag = href ? 'a' : 'button';
---

<Tag href={href} type={!href ? type : undefined} class={classes} aria-label={ariaLabel}>
  <slot />
</Tag>
