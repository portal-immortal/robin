---
import { Image } from 'astro:assets';
import { Icon } from 'astro-icon/components';
import Card from './Card.astro';

interface Props {
  name: string;
  role: string;
  subject?: string;
  image: ImageMetadata;
  class?: string;
}

const { name, role, subject, image, class: className = '' } = Astro.props;
---

<Card as="article" class={`overflow-hidden p-0! ${className}`}>
  <div class="bg-primary-50 dark:bg-primary-800 aspect-square w-full overflow-hidden">
    <Image
      src={image}
      alt={`Foto ${role} ${name}`}
      width={400}
      height={400}
      class="h-full w-full object-cover transition-transform duration-500 hover:scale-105"
      loading="lazy"
    />
  </div>
  <div class="flex flex-col gap-1 p-5 text-center">
    <h3 class="text-ink dark:text-primary-50 text-base font-semibold">{name}</h3>
    <p
      class="text-primary-600 dark:text-primary-300 flex items-center justify-center gap-1.5 text-sm font-medium"
    >
      <Icon name="ph:graduation-cap" class="h-4 w-4" aria-hidden="true" />
      {role}
    </p>
    {subject && <p class="text-ink/60 dark:text-primary-100/60 text-xs">{subject}</p>}
  </div>
</Card>
