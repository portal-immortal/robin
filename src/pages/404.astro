---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Button from '@/components/Button.astro';
import { NAV_LINKS } from '@/utils/site';

const quickLinks = NAV_LINKS.filter((l) => ['/', '/program', '/ppdb', '/kontak'].includes(l.href));
---

<BaseLayout
  title="Halaman Tidak Ditemukan"
  description="Halaman yang Anda cari tidak ditemukan di website Pondok Pesantren Roudhotuttholibin."
>
  <section class="section-pad bg-geo-pattern flex min-h-[70vh] items-center bg-repeat">
    <div class="container-page">
      <div class="mx-auto flex max-w-xl flex-col items-center gap-6 text-center">
        <span
          class="bg-gradient-emerald shadow-gold flex h-20 w-20 items-center justify-center rounded-full text-3xl font-bold text-white"
          aria-hidden="true"
        >
          404
        </span>
        <h1 class="text-display-md">Halaman Tidak Ditemukan</h1>
        <p class="text-ink/70 dark:text-primary-100/70">
          Mohon maaf, halaman yang Anda cari tidak tersedia atau mungkin telah dipindahkan. Silakan
          kembali ke beranda atau kunjungi salah satu halaman berikut.
        </p>

        <div class="flex flex-wrap items-center justify-center gap-3 pt-2">
          <Button href="/" size="lg">Kembali ke Beranda</Button>
        </div>

        <nav
          aria-label="Tautan cepat"
          class="flex flex-wrap items-center justify-center gap-2 pt-6"
        >
          {
            quickLinks.map((link) => (
              <a
                href={link.href}
                class="border-primary-200 text-ink/70 hover:bg-primary-50 hover:text-primary-700 dark:border-primary-700 dark:text-primary-100/70 dark:hover:bg-primary-900 rounded-full border px-4 py-2 text-sm font-medium transition-colors"
              >
                {link.label}
              </a>
            ))
          }
        </nav>
      </div>
    </div>
  </section>
</BaseLayout>
